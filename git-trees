#!/usr/bin/env bash
# Live git worktree status dashboard — run from any git repo
# Usage: git-trees [refresh_seconds]
#   Defaults to 5s refresh. Pass 0 for single run.

set -euo pipefail

INTERVAL="${1:-5}"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Not a git repository." >&2; exit 1
}
REPO_NAME="$(basename "$REPO_ROOT")"

# Colors — $'...' so variables contain raw ESC bytes
R=$'\033[0m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
RED=$'\033[31m'
CYAN=$'\033[36m'
MAGENTA=$'\033[35m'
BLUE=$'\033[34m'
CLAUDE_ORANGE=$'\033[38;2;217;119;87m'
SESSION_ICON="󱚦"
CODEX_DIR="$HOME/.codex"
CLR_EOL=$'\033[K'
MAX_CODEX_LABEL=35
SESSION_ALIVE_SECS=28800  # 8 hours

# Session heartbeat dir (written by starship-claude status line)
HEARTBEAT_DIR="$HOME/.claude/session-heartbeats"

# Persistent temp files (reused across render cycles — no leak)
CLAUDE_SESSION_MAP="$(mktemp)"
RENDER_FILE="$(mktemp)"
TMP_ALL="$(mktemp)"
WT_LIST_FILE="$(mktemp)"
ORPHAN_PR_FILE="$(mktemp)"
TMP_FILES=("$CLAUDE_SESSION_MAP" "$RENDER_FILE" "$TMP_ALL" "$WT_LIST_FILE" "$ORPHAN_PR_FILE")

# Shared state — set once per render cycle in render_to_file()
NOW_TS=0
AGE_COL=0
FETCH_PID=""
PR_MAP_FILE="$REPO_ROOT/.git/trees-pr-cache"
MY_PR_FILE="$REPO_ROOT/.git/trees-my-prs"
PR_NUM=""
PR_URL=""
PR_STATE=""
PR_CI=""

# Sets PR_NUM, PR_URL, PR_STATE, and PR_CI for the given branch
lookup_pr() {
  PR_NUM="" PR_URL="" PR_STATE="" PR_CI=""
  [[ -s "$PR_MAP_FILE" ]] || return 0
  local line
  line="$(grep "^${1}	" "$PR_MAP_FILE" 2>/dev/null | head -1 || true)"
  [[ -n "$line" ]] || return 0
  IFS=$'\t' read -r _ PR_NUM PR_URL PR_STATE PR_CI <<< "$line"
}

# Sets REPLY instead of echoing — avoids subshell fork at call sites
format_age() {
  local s="$1"
  if (( s < 60 )); then REPLY="now"
  elif (( s < 3600 )); then REPLY="$(( s / 60 ))m"
  elif (( s < 86400 )); then REPLY="$(( s / 3600 ))h"
  else REPLY="$(( s / 86400 ))d"
  fi
}

scan_claude_sessions() {
  > "$CLAUDE_SESSION_MAP"
  [[ -d "$HEARTBEAT_DIR" ]] || return

  > "$TMP_ALL"

  for f in "$HEARTBEAT_DIR"/*; do
    [[ -f "$f" ]] || continue
    local hb_line
    IFS= read -r hb_line < "$f" 2>/dev/null || continue
    [[ -n "$hb_line" ]] || continue

    # Field 1 and 2 are always non-empty — safe to extract with bash
    local hb_repo="${hb_line%%$'\t'*}"
    [[ "$hb_repo" == "$REPO_ROOT" ]] || continue
    local hb_rest="${hb_line#*$'\t'}"
    local hb_wt="${hb_rest%%$'\t'*}"
    # Field 5 (ts) — extract with param expansion (avoids fork)
    local hb_ts="$hb_line"
    hb_ts="${hb_ts#*$'\t'}"; hb_ts="${hb_ts#*$'\t'}"
    hb_ts="${hb_ts#*$'\t'}"; hb_ts="${hb_ts#*$'\t'}"
    hb_ts="${hb_ts%%$'\t'*}"

    local sid="${f##*/}"
    local alive=0
    (( NOW_TS - ${hb_ts:-0} < SESSION_ALIVE_SECS )) && alive=1

    printf '%s\t%s\t%s\t%s\n' "$hb_wt" "${hb_ts:-0}" "$sid" "$alive" >> "$TMP_ALL"
  done

  if [[ -s "$TMP_ALL" ]]; then
    sort -t$'\t' -k1,1 -k2,2rn "$TMP_ALL" > "$CLAUDE_SESSION_MAP"
  fi
}

get_claude_sessions() {
  local key="$1"
  [[ -s "$CLAUDE_SESSION_MAP" ]] || return
  grep "^${key}	" "$CLAUDE_SESSION_MAP" 2>/dev/null || true
}

# Sets REPLY to display length of label [+ " on " + branch]
calc_display_len() {
  if [[ "${2##*/}" != "$1" ]]; then
    REPLY=$(( ${#1} + 4 + ${#2} ))
  else
    REPLY=${#1}
  fi
}

# Reads ESC [ X sequence, sets REPLY to mapped key or ""
decode_arrow() {
  local b1="" b2=""
  read -rsn1 -t "${1:-1}" b1 2>/dev/null || true
  if [[ "$b1" == "[" ]]; then
    read -rsn1 -t "${1:-1}" b2 2>/dev/null || true
    case "$b2" in
      A) REPLY="J" ;;  # up arrow → scroll up
      B) REPLY="K" ;;  # down arrow → scroll down
      *) REPLY="" ;;
    esac
  else
    REPLY=""
  fi
}

print_status() {
  local dir="$1" label="$2" wt_type="$3" session_key="$4" commit_ts="$5" branch="$6" dev_behind="${7:-0}" dev_ahead="${8:-0}" matched_branch="${9:-}"

  # Ahead/behind tracking branch
  local ahead=0 behind=0 upstream
  upstream="$(git -C "$dir" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"
  if [[ -n "$upstream" ]]; then
    local ab
    ab="$(git -C "$dir" rev-list --left-right --count HEAD..."$upstream" 2>/dev/null || echo "0	0")"
    IFS=$'\t' read -r ahead behind <<< "$ab"
  fi

  # File counts (two case passes — bash 3.2 has no ;;&)
  local staged=0 modified=0 untracked=0 status_output
  status_output="$(git -C "$dir" status --porcelain 2>/dev/null || true)"
  if [[ -n "$status_output" ]]; then
    while IFS= read -r sline; do
      case "${sline:0:2}" in
        '??') (( untracked++ )); continue ;;
      esac
      case "${sline:0:1}" in
        [MADRC]) (( staged++ )) ;;
      esac
      case "${sline:1:1}" in
        [MD]) (( modified++ )) ;;
      esac
    done <<< "$status_output"
  fi

  # Last commit age
  local age_str=""
  if (( commit_ts > 0 )); then
    format_age $(( NOW_TS - commit_ts )); age_str="$REPLY"
  fi

  # Build display name and compute padding
  local name_color="$CYAN"
  [[ "$wt_type" == "main" ]] && name_color="$MAGENTA"
  [[ "$wt_type" == "codex" ]] && name_color="$BLUE"

  local show_branch=0
  [[ "${branch##*/}" != "$label" ]] && show_branch=1
  calc_display_len "$label" "$branch"
  local display_len=$REPLY name_len=$REPLY

  # PR lookup (skip for main repo — it shows whatever branch is checked out, not a feature branch)
  if [[ "$wt_type" == "main" ]]; then
    PR_NUM="" PR_URL="" PR_STATE="" PR_CI=""
  else
    lookup_pr "$branch"
  fi
  if [[ -n "$PR_NUM" ]]; then
    (( display_len += 4 + ${#PR_NUM} ))
    [[ -n "$PR_CI" || "$PR_STATE" == "MERGED" ]] && (( display_len += 2 ))
  fi
  if (( dev_behind > 0 )); then
    (( display_len += 12 + ${#dev_behind} ))
  fi
  if (( dev_ahead > 0 )); then
    (( display_len += 2 + ${#dev_ahead} ))
  fi
  # Truncate label to fit terminal width
  local extras_len=$(( display_len - name_len ))
  local max_name=$(( AGE_COL - 4 - extras_len ))
  if (( name_len > max_name && max_name > 3 )); then
    if (( show_branch )); then
      show_branch=0
      if (( ${#label} > max_name )); then
        label="${label:0:$((max_name - 1))}…"
        name_len=$max_name
      else
        name_len=${#label}
      fi
    else
      label="${label:0:$((max_name - 1))}…"
      name_len=$max_name
    fi
    display_len=$(( name_len + extras_len ))
  fi
  local pad=$(( AGE_COL - 2 - display_len ))
  (( pad < 2 )) && pad=2

  printf "  "
  if (( show_branch )); then
    printf "${name_color}${BOLD}%s${R} ${DIM}on${R} ${BOLD}%s${R}" "$label" "$branch"
  else
    printf "${name_color}${BOLD}%s${R}" "$label"
  fi
  if [[ -n "$PR_NUM" ]]; then
    printf ' \033]8;;%s\007%s(#%s)%s\033]8;;\007' "$PR_URL" "$DIM" "$PR_NUM" "$R"
    if [[ "$PR_STATE" == "MERGED" ]]; then
      printf " ${MAGENTA}●${R}"
    else
      case "$PR_CI" in
        pass)    printf " ${GREEN}✓${R}" ;;
        fail)    printf " ${RED}✗${R}" ;;
        pending) printf " ${YELLOW}○${R}" ;;
      esac
    fi
  fi
  if (( dev_behind > 0 )); then
    printf "  ${YELLOW}develop ↓ %d${R}" "$dev_behind"
  fi
  if (( dev_ahead > 0 )); then
    printf " ${GREEN}+%d${R}" "$dev_ahead"
  fi
  printf "%-${pad}s" ""
  [[ -n "$age_str" ]] && printf "${DIM}%3s${R}" "$age_str"

  # Codex indicator
  [[ "$wt_type" == "codex" ]] && printf "\n    ${BLUE}${SESSION_ICON}  codex${R}"

  # Claude session indicators (skip for main repo — sessions pile up and never clean up)
  if [[ "$wt_type" != "main" ]]; then
    local session_lines
    session_lines="$(get_claude_sessions "$session_key")"
    if [[ -n "$session_lines" ]]; then
      while IFS= read -r session_line; do
        [[ -n "$session_line" ]] || continue
        local s_mtime s_id s_alive
        IFS=$'\t' read -r _ s_mtime s_id s_alive <<< "$session_line"
        format_age $(( NOW_TS - s_mtime )); local s_age="$REPLY"
        # Use absolute-column escape (CHA) to align age — avoids icon display-width ambiguity
        local s_age_col=$(( AGE_COL + 1 ))
        if (( s_alive )); then
          printf "\n    ${CLAUDE_ORANGE}${SESSION_ICON}${R}  ${DIM}%s\e[%dG%3s${R}" "$s_id" "$s_age_col" "$s_age"
        else
          printf "\n    ${DIM}${SESSION_ICON}  %s\e[%dG%3s${R}" "$s_id" "$s_age_col" "$s_age"
        fi
      done <<< "$session_lines"
    fi
  fi
  echo

  # Status badges (only print line if there are any)
  local badges="" sep=""
  if [[ -n "$upstream" ]]; then
    if ! git -C "$dir" rev-parse --verify "refs/remotes/$upstream" &>/dev/null; then
      badges+="${RED}gone${R}"; sep="  "
    fi
  fi
  if (( ahead > 0 )); then
    badges+="${sep}${GREEN}↑  ${ahead}${R}"
    [[ -n "$matched_branch" ]] && badges+="  ${DIM}(${matched_branch})${R}"
    sep="  "
  fi
  (( behind > 0 )) && { badges+="${sep}${RED}↓  ${behind}${R}"; sep="  "; }
  (( staged > 0 )) && { badges+="${sep}${GREEN}●  ${staged} staged${R}"; sep="  "; }
  (( modified > 0 )) && { badges+="${sep}${YELLOW}●  ${modified} modified${R}"; sep="  "; }
  (( untracked > 0 )) && { badges+="${sep}${DIM}+ ${untracked} untracked${R}"; sep="  "; }
  [[ -n "$badges" ]] && printf "    %b\n" "$badges"
  echo
}

print_orphan_pr() {
  local branch="$1" pr_num="$2" pr_url="$3" pr_state="$4" pr_ci="$5" commit_ts="$6" is_draft="$7" dev_ahead="${8:-0}"

  local age_str=""
  if (( commit_ts > 0 )); then
    format_age $(( NOW_TS - commit_ts )); age_str="$REPLY"
  fi

  local display_len=${#branch}
  (( display_len += 4 + ${#pr_num} ))
  [[ -n "$is_draft" ]] && (( display_len += 6 ))
  [[ -n "$pr_ci" || "$pr_state" == "MERGED" ]] && (( display_len += 2 ))
  if (( dev_ahead > 0 )); then
    (( display_len += 2 + ${#dev_ahead} ))
  fi
  # Truncate branch name to fit terminal width
  local name_len=${#branch}
  local extras_len=$(( display_len - name_len ))
  local max_name=$(( AGE_COL - 4 - extras_len ))
  if (( name_len > max_name && max_name > 3 )); then
    branch="${branch:0:$((max_name - 1))}…"
    display_len=$(( ${#branch} + extras_len ))
  fi

  local pad=$(( AGE_COL - 2 - display_len ))
  (( pad < 2 )) && pad=2

  if [[ -n "$is_draft" ]]; then
    printf "  ${DIM}%s${R}" "$branch"
  else
    printf "  ${BOLD}%s${R}" "$branch"
  fi
  printf ' \033]8;;%s\007%s(#%s)%s\033]8;;\007' "$pr_url" "$DIM" "$pr_num" "$R"
  [[ -n "$is_draft" ]] && printf " ${DIM}draft${R}"
  if [[ "$pr_state" == "MERGED" ]]; then
    printf " ${MAGENTA}●${R}"
  else
    case "$pr_ci" in
      pass)    printf " ${GREEN}✓${R}" ;;
      fail)    printf " ${RED}✗${R}" ;;
      pending) printf " ${YELLOW}○${R}" ;;
    esac
  fi
  if (( dev_ahead > 0 )); then
    printf " ${GREEN}+%d${R}" "$dev_ahead"
  fi
  printf "%-${pad}s" ""
  [[ -n "$age_str" ]] && printf "${DIM}%3s${R}" "$age_str"
  echo
  echo
}

render_to_file() {
  NOW_TS="$(date +%s)"

  # Background fetch (throttled to every 30s)
  local fetch_stamp="$REPO_ROOT/.git/trees-fetch-ts"
  local last_fetch=0
  if [[ -f "$fetch_stamp" ]]; then
    IFS= read -r last_fetch < "$fetch_stamp" 2>/dev/null || true
  fi
  if (( NOW_TS - last_fetch > 30 )); then
    [[ -n "${FETCH_PID:-}" ]] && wait "$FETCH_PID" 2>/dev/null || true
    GIT_TERMINAL_PROMPT=0 git -C "$REPO_ROOT" fetch --quiet 2>/dev/null &
    FETCH_PID=$!
    echo "$NOW_TS" > "$fetch_stamp" 2>/dev/null || true
  fi

  scan_claude_sessions

  # Build codex cache before worktree loop (runs at most once per index change)
  local cache_file="$HOME/.claude/codex-wt-cache"
  if [[ -f "$CODEX_DIR/session_index.jsonl" ]]; then
    local idx_mtime cache_mtime
    idx_mtime="$(stat -f "%m" "$CODEX_DIR/session_index.jsonl" 2>/dev/null || echo 0)"
    cache_mtime="$(stat -f "%m" "$cache_file" 2>/dev/null || echo 0)"
    if (( idx_mtime > cache_mtime )); then
      python3 -c "
import json, glob, os
idx = '$CODEX_DIR/session_index.jsonl'
sdir = '$CODEX_DIR/sessions'
names = {}
with open(idx) as f:
    for l in f:
        try:
            d = json.loads(l)
            names[d['id']] = d.get('thread_name','')
        except: pass
files = sorted(glob.glob(os.path.join(sdir, '**/*.jsonl'), recursive=True), key=os.path.getmtime, reverse=True)[:20]
seen = {}
for fp in files:
    try:
        with open(fp) as sf:
            p = json.loads(sf.readline()).get('payload', {})
        cwd = p.get('cwd', '')
        if '/.codex/worktrees/' not in cwd: continue
        wt_hash = cwd.split('/worktrees/')[1].split('/')[0]
        if wt_hash in seen: continue
        sid = p.get('id', '')
        seen[wt_hash] = names.get(sid, '')
    except: continue
with open('$cache_file', 'w') as out:
    for h, n in seen.items():
        out.write(f'{h}\t{n}\n')
" 2>/dev/null || true
    fi
  fi

  # Collect worktrees: commit_ts \t type \t dir \t label \t branch \t dev_ahead
  local HAS_ORIGIN_DEV=0
  git -C "$REPO_ROOT" rev-parse --verify origin/develop &>/dev/null && HAS_ORIGIN_DEV=1
  > "$WT_LIST_FILE"
  local wt_count=0

  while IFS= read -r line; do
    local wt_dir="${line%% *}"
    [[ "$wt_dir" == "$REPO_ROOT" ]] && continue

    local wt_ts wt_branch
    wt_ts="$(git -C "$wt_dir" log -1 --format='%ct' 2>/dev/null || echo 0)"
    wt_branch="$(git -C "$wt_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo detached)"

    case "$wt_dir" in
      "$REPO_ROOT"/*)
        local wt_label="${wt_dir#"$REPO_ROOT"/.worktrees/}"
        # .claude/worktrees/agent-xxx → just show final dir name
        [[ "$wt_label" == "$wt_dir" ]] && wt_label="${wt_dir##*/}"
        # If label matches branch (e.g. kevin/foo dir → kevin/foo label), use basename
        [[ "$wt_label" == "$wt_branch" ]] && wt_label="${wt_branch##*/}"
        local wt_dev_ahead=0
        (( HAS_ORIGIN_DEV )) && wt_dev_ahead="$(git -C "$wt_dir" rev-list --count origin/develop..HEAD 2>/dev/null || echo 0)"
        printf '%s\tlocal\t%s\t%s\t%s\t%s\n' "$wt_ts" "$wt_dir" "$wt_label" "$wt_branch" "$wt_dev_ahead" >> "$WT_LIST_FILE"
        (( wt_count++ ))
        ;;
      */.codex/worktrees/*)
        # Hide codex worktrees still on develop (no meaningful work)
        [[ "$wt_branch" == "develop" ]] && continue
        local codex_hash="${wt_dir##*/worktrees/}"
        codex_hash="${codex_hash%%/*}"
        local codex_label
        codex_label="$(grep "^${codex_hash}	" "$cache_file" 2>/dev/null | cut -f2 || true)"
        codex_label="${codex_label:-codex:${codex_hash}}"
        if [[ "$wt_branch" != "HEAD" && "$wt_branch" != "detached" ]]; then
          codex_label="${wt_branch##*/}"
        fi
        # Truncate inline — no second pass needed
        if (( ${#codex_label} > MAX_CODEX_LABEL )); then
          codex_label="${codex_label:0:$((MAX_CODEX_LABEL - 1))}…"
        fi
        local wt_dev_ahead=0
        (( HAS_ORIGIN_DEV )) && wt_dev_ahead="$(git -C "$wt_dir" rev-list --count origin/develop..HEAD 2>/dev/null || echo 0)"
        printf '%s\tcodex\t%s\t%s\t%s\t%s\n' "$wt_ts" "$wt_dir" "$codex_label" "$wt_branch" "$wt_dev_ahead" >> "$WT_LIST_FILE"
        (( wt_count++ ))
        ;;
    esac
  done < <(git -C "$REPO_ROOT" worktree list)

  sort -t$'\t' -k1,1rn -o "$WT_LIST_FILE" "$WT_LIST_FILE"

  # Compute max display width
  local main_branch main_commit_ts
  main_branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo detached)"
  main_commit_ts="$(git -C "$REPO_ROOT" log -1 --format='%ct' 2>/dev/null || echo 0)"

  # PR data — background per-branch fetch, persistent cache (throttled to every 60s)
  local pr_stamp="$REPO_ROOT/.git/trees-pr-ts"
  local last_pr=0
  if [[ -f "$pr_stamp" ]]; then
    IFS= read -r last_pr < "$pr_stamp" 2>/dev/null || true
  fi
  if (( NOW_TS - last_pr > 60 )); then
    echo "$NOW_TS" > "$pr_stamp" 2>/dev/null || true
    local pr_branches=("$main_branch")
    while IFS=$'\t' read -r _ _ _ _ wb _; do
      pr_branches+=("$wb")
    done < "$WT_LIST_FILE"
    (
      local pr_tmp; pr_tmp="$(mktemp)"
      local jq_expr='.[] | [.headRefName, (.number | tostring), .url, .state, (
        (.statusCheckRollup // []) as $c |
        if ($c | length) == 0 then ""
        elif ($c | any(.conclusion == "FAILURE" or .conclusion == "TIMED_OUT" or .conclusion == "ACTION_REQUIRED" or .state == "FAILURE" or .state == "ERROR")) then "fail"
        elif ($c | any(.status == "IN_PROGRESS" or .status == "QUEUED" or .state == "PENDING")) then "pending"
        else "pass" end
      )] | @tsv'
      cd "$REPO_ROOT" || exit
      for b in "${pr_branches[@]}"; do
        gh pr list --head "$b" --state all --limit 1 \
          --json headRefName,number,url,state,statusCheckRollup \
          --jq "$jq_expr" 2>/dev/null >> "$pr_tmp" || true
      done
      mv "$pr_tmp" "$PR_MAP_FILE"
      # Fetch all my open PRs (includes isDraft)
      local my_tmp; my_tmp="$(mktemp)"
      local my_jq='.[] | [.headRefName, (.number | tostring), .url, .state, (
        (.statusCheckRollup // []) as $c |
        if ($c | length) == 0 then ""
        elif ($c | any(.conclusion == "FAILURE" or .conclusion == "TIMED_OUT" or .conclusion == "ACTION_REQUIRED" or .state == "FAILURE" or .state == "ERROR")) then "fail"
        elif ($c | any(.status == "IN_PROGRESS" or .status == "QUEUED" or .state == "PENDING")) then "pending"
        else "pass" end
      ), (if .isDraft then "draft" else "" end)] | @tsv'
      gh pr list --author @me --state open \
        --json headRefName,number,url,state,statusCheckRollup,isDraft \
        --jq "$my_jq" 2>/dev/null > "$my_tmp" || true
      mv "$my_tmp" "$MY_PR_FILE"
    ) &
  fi

  # Build orphan PR list (open PRs without a local worktree)
  > "$ORPHAN_PR_FILE"
  local orphan_count=0
  if [[ -s "$MY_PR_FILE" ]]; then
    local wt_branches_list="$main_branch"
    while IFS=$'\t' read -r _ _ _ _ wb _; do
      wt_branches_list+=$'\n'"$wb"
    done < "$WT_LIST_FILE"
    while IFS=$'\t' read -r op_branch op_num op_url op_state op_ci op_draft; do
      if printf '%s\n' "$wt_branches_list" | grep -qxF "$op_branch" 2>/dev/null; then
        continue
      fi
      # Fuzzy match: PR branch like claude/foo-XXXXX → worktree dir foo
      local op_basename="${op_branch##*/}"
      local best_wt_branch="" best_len=0
      while IFS=$'\t' read -r _ _ fwt_dir _ fwt_branch _; do
        local fwt_stem="${fwt_dir##*/}"
        if [[ ("$op_basename" == "$fwt_stem" || "$op_basename" == "${fwt_stem}-"*) && ${#fwt_stem} -gt $best_len ]]; then
          best_wt_branch="$fwt_branch" best_len=${#fwt_stem}
        fi
      done < "$WT_LIST_FILE"
      if [[ -n "$best_wt_branch" ]]; then
        printf '%s\t%s\t%s\t%s\t%s\n' "$best_wt_branch" "$op_num" "$op_url" "$op_state" "$op_ci" >> "$PR_MAP_FILE"
        continue
      fi
      local op_ts op_dev_ahead=0
      op_ts="$(git -C "$REPO_ROOT" log -1 --format='%ct' "origin/$op_branch" 2>/dev/null || echo 0)"
      (( HAS_ORIGIN_DEV )) && op_dev_ahead="$(git -C "$REPO_ROOT" rev-list --count origin/develop.."origin/$op_branch" 2>/dev/null || echo 0)"
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$op_ts" "$op_branch" "$op_num" "$op_url" "$op_state" "$op_ci" "$op_draft" "$op_dev_ahead" >> "$ORPHAN_PR_FILE"
      (( orphan_count++ ))
    done < "$MY_PR_FILE"
    (( orphan_count > 0 )) && sort -t$'\t' -k1,1rn -o "$ORPHAN_PR_FILE" "$ORPHAN_PR_FILE"
  fi

  local dev_behind=0
  if (( HAS_ORIGIN_DEV )); then
    dev_behind="$(git -C "$REPO_ROOT" rev-list --count HEAD..origin/develop 2>/dev/null || echo 0)"
  fi

  # Detect if main repo HEAD is synced from a worktree branch
  local matched_branch=""
  if [[ -s "$WT_LIST_FILE" ]]; then
    # Fast path: exact tree SHA match (branch tip has identical file state)
    local main_tree_sha
    main_tree_sha="$(git -C "$REPO_ROOT" rev-parse HEAD^{tree} 2>/dev/null || true)"
    if [[ -n "$main_tree_sha" ]]; then
      while IFS=$'\t' read -r _ _ _ _ wt_branch _; do
        local wt_tree
        wt_tree="$(git -C "$REPO_ROOT" rev-parse "refs/heads/$wt_branch^{tree}" 2>/dev/null || true)"
        if [[ "$main_tree_sha" == "$wt_tree" ]]; then
          matched_branch="$wt_branch"
          break
        fi
      done < "$WT_LIST_FILE"
    fi
    # Fallback: latest commit message match (branch moved ahead after sync)
    if [[ -z "$matched_branch" ]] && (( HAS_ORIGIN_DEV )); then
      local main_latest_msg
      main_latest_msg="$(git -C "$REPO_ROOT" log -1 --format='%s' origin/develop..HEAD 2>/dev/null || true)"
      if [[ -n "$main_latest_msg" ]]; then
        while IFS=$'\t' read -r _ _ _ _ wt_branch _; do
          if git -C "$REPO_ROOT" log --format='%s' "origin/develop..refs/heads/$wt_branch" 2>/dev/null | grep -qxF "$main_latest_msg"; then
            matched_branch="$wt_branch"
            break
          fi
        done < "$WT_LIST_FILE"
      fi
    fi
  fi

  local max_display=$(( ${#REPO_NAME} + 4 + ${#main_branch} ))
  if (( dev_behind > 0 )); then
    (( max_display += 12 + ${#dev_behind} ))
  fi
  while IFS=$'\t' read -r _ _ _ wt_label wt_branch wt_dev_ahead; do
    calc_display_len "$wt_label" "$wt_branch"
    local wd=$REPLY
    lookup_pr "$wt_branch"
    if [[ -n "$PR_NUM" ]]; then
      (( wd += 4 + ${#PR_NUM} ))
      [[ -n "$PR_CI" || "$PR_STATE" == "MERGED" ]] && (( wd += 2 ))
    fi
    if (( ${wt_dev_ahead:-0} > 0 )); then
      (( wd += 2 + ${#wt_dev_ahead} ))
    fi
    (( wd > max_display )) && max_display=$wd
  done < "$WT_LIST_FILE"

  while IFS=$'\t' read -r _ op_branch op_num _ op_state op_ci op_draft op_dev_ahead; do
    local wd=${#op_branch}
    (( wd += 4 + ${#op_num} ))
    [[ -n "$op_draft" ]] && (( wd += 6 ))
    [[ -n "$op_ci" || "$op_state" == "MERGED" ]] && (( wd += 2 ))
    if (( ${op_dev_ahead:-0} > 0 )); then
      (( wd += 2 + ${#op_dev_ahead} ))
    fi
    (( wd > max_display )) && max_display=$wd
  done < "$ORPHAN_PR_FILE"

  AGE_COL=$(( max_display + 4 ))
  (( AGE_COL < 45 )) && AGE_COL=45
  (( AGE_COL > TERM_W - 5 )) && AGE_COL=$(( TERM_W - 5 ))
  (( AGE_COL < 10 )) && AGE_COL=10

  {
    echo  # blank row — some terminals hide row 1 in alt screen
    local time_str
    time_str="$(date '+%I:%M:%S %p')"; time_str="${time_str#0}"
    printf "${BOLD}  %s${R}  ${DIM}%s worktrees" "$REPO_NAME" "$wt_count"
    (( orphan_count > 0 )) && printf "  %d PR%s" "$orphan_count" "$( (( orphan_count != 1 )) && echo 's' || true)"
    printf "  %s${R}\n" "$time_str"
    local hr_width=$(( AGE_COL - 2 ))
    printf "  ${DIM}%s${R}\n" "$(printf '%*s' "$hr_width" '' | tr ' ' '─')"

    # Main repo (always first)
    print_status "$REPO_ROOT" "$REPO_NAME" "main" "__main__" "$main_commit_ts" "$main_branch" "$dev_behind" "0" "$matched_branch"

    # Other worktrees sorted by activity
    while IFS=$'\t' read -r ts wt_type wt_dir wt_label wt_branch wt_dev_ahead; do
      local session_key
      if [[ "$wt_type" == "codex" ]]; then
        session_key="__codex__/${wt_dir##*/}"
      else
        session_key="${wt_dir##*/}"
      fi
      print_status "$wt_dir" "$wt_label" "$wt_type" "$session_key" "$ts" "$wt_branch" "0" "${wt_dev_ahead:-0}"
    done < "$WT_LIST_FILE"

    # Orphan PRs (open, authored by me, no local worktree)
    if (( orphan_count > 0 )); then
      while IFS=$'\t' read -r op_ts op_branch op_num op_url op_state op_ci op_draft op_dev_ahead; do
        print_orphan_pr "$op_branch" "$op_num" "$op_url" "$op_state" "$op_ci" "$op_ts" "$op_draft" "${op_dev_ahead:-0}"
      done < "$ORPHAN_PR_FILE"
    fi

  } | sed "s/$/$CLR_EOL/" > "$RENDER_FILE"
  TOTAL_LINES=0
  while IFS= read -r _; do (( ++TOTAL_LINES )); done < "$RENDER_FILE"
}

SCROLL_OFFSET=0
TOTAL_LINES=0
TERM_H=0
TERM_W=80
IS_REFRESHING=0
update_term_h() { TERM_H=$(tput lines); TERM_W=$(tput cols); (( TERM_H < 3 )) && TERM_H=3 || true; (( TERM_W < 20 )) && TERM_W=20 || true; }

paint() {
  local visible start end
  if (( TOTAL_LINES <= TERM_H )); then
    SCROLL_OFFSET=0
    start=1; end=$TOTAL_LINES
  else
    local max_scroll=$(( TOTAL_LINES - TERM_H + 1 ))
    (( SCROLL_OFFSET > max_scroll )) && SCROLL_OFFSET=$max_scroll
    (( SCROLL_OFFSET < 0 )) && SCROLL_OFFSET=0
    start=$(( SCROLL_OFFSET + 1 ))
    end=$(( SCROLL_OFFSET + TERM_H - 1 ))
  fi

  printf '\033[1;1H'
  sed -n "${start},${end}p" "$RENDER_FILE"

  # Dynamic footer
  if (( INTERVAL > 0 )); then
    local ri="◇"
    (( IS_REFRESHING )) && ri="◆"
    if (( TOTAL_LINES > TERM_H )); then
      local below=$(( TOTAL_LINES - end ))
      local hint=""
      (( SCROLL_OFFSET > 0 && below > 0 )) && hint="↑ ${SCROLL_OFFSET}  ↓ ${below}"
      (( SCROLL_OFFSET > 0 && below <= 0 )) && hint="↑ ${SCROLL_OFFSET}"
      (( SCROLL_OFFSET == 0 && below > 0 )) && hint="↓ ${below} more"
      printf '%s%s  %s  %s  j/k g/G%s\n' "$CLR_EOL" "$DIM" "$ri" "$hint" "$R"
    fi
  fi
  printf '\033[J'
}

# Single run
if (( INTERVAL == 0 )); then
  update_term_h
  render_to_file
  cat "$RENDER_FILE"
  rm -f "${TMP_FILES[@]}"
  exit 0
fi

# Live mode
ORIG_STTY="$(stty -g)"
cleanup() { stty "$ORIG_STTY" 2>/dev/null; printf '\e[?1000l\e[?1002l\e[?1003l'; tput cnorm; tput rmcup; rm -f "${TMP_FILES[@]}"; exit 0; }
trap cleanup INT TERM

update_term_h
render_to_file
tput smcup
printf '\033[r\033[H\033[2J'
tput civis
printf '\e[?1000l\e[?1002l\e[?1003l'
stty -echo -icanon min 0 time 0
paint

RESIZED=0
# Only set flag in WINCH handler — never fork (tput) inside a signal handler.
# Forking during rapid resizes causes subprocess pileup → SIGKILL.
trap 'RESIZED=1' WINCH

LAST_RENDER=$SECONDS
LAST_SCROLL=0
SCROLL_COOLDOWN=2
while true; do
  # Time-based full render — deferred while user is scrolling
  if (( RESIZED )); then
    update_term_h
  fi
  if (( RESIZED || SECONDS - LAST_RENDER >= INTERVAL )) && (( SECONDS - LAST_SCROLL >= SCROLL_COOLDOWN )); then
    RESIZED=0
    IS_REFRESHING=1; paint
    render_to_file
    IS_REFRESHING=0; paint
    LAST_RENDER=$SECONDS
  fi

  if read -rsn1 -t 1 key 2>/dev/null; then
    [[ "$key" == "q" || "$key" == "Q" ]] && break
    [[ "$key" == "r" || "$key" == "R" ]] && { LAST_RENDER=0; continue; }
    # Decode arrow keys: ESC [ A/B
    if [[ "$key" == $'\033' ]]; then
      decode_arrow 1; key="$REPLY"
    fi
    if [[ "$key" == "k" || "$key" == "K" || "$key" == "j" || "$key" == "J" ]]; then
      delta=0
      [[ "$key" == "j" || "$key" == "J" ]] && (( delta-- ))
      [[ "$key" == "k" || "$key" == "K" ]] && (( delta++ ))
      while read -rsn1 -t 0 extra 2>/dev/null; do
        case "$extra" in
          j|J) (( delta-- )) ;;
          k|K) (( delta++ )) ;;
          $'\033') decode_arrow 0
            case "$REPLY" in J) (( delta-- )) ;; K) (( delta++ )) ;; esac ;;
        esac
      done
      (( SCROLL_OFFSET += delta ))
      LAST_SCROLL=$SECONDS; paint
    fi
    [[ "$key" == "g" ]] && { SCROLL_OFFSET=0; LAST_SCROLL=$SECONDS; paint; }
    [[ "$key" == "G" ]] && { SCROLL_OFFSET=$TOTAL_LINES; LAST_SCROLL=$SECONDS; paint; }
  fi
done

cleanup
